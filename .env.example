# Server
PORT=3000

# Anthropic (required for planning/decomposition)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Nimble agent web search (required for planning + debate web search)
# Endpoint + auth span two Nimble product generations; configure for your account.
NIMBLE_BASE_URL=https://api.webit.live/api/v1/realtime/serp
# Either provide a full Authorization header value...
NIMBLE_AUTH_HEADER=
# ...or Basic-auth credentials (username:password) which the client base64-encodes.
NIMBLE_USERNAME=
NIMBLE_PASSWORD=
# ...or a Bearer token.
NIMBLE_API_KEY=
NIMBLE_SEARCH_ENGINE=google_search

# Datadog LLM Observability ("LapDog")
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=peercode
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_API_KEY=
DD_SITE=datadoghq.com

# ClickHouse (append-only streams: deltas, debate messages, events, audit)
# ClickHouse Cloud: use the HTTPS endpoint (port 8443), e.g.
#   CLICKHOUSE_URL=https://<id>.<region>.clickhouse.cloud:8443
#   CLICKHOUSE_USER=default
#   CLICKHOUSE_PASSWORD=<your cloud password>
# Local Docker: http://localhost:8123, user default, empty password.
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=peercode

# GitHub (OPTIONAL, read-only — sessions own all pushes; server never pushes)
GITHUB_TOKEN=
GITHUB_REPO=
