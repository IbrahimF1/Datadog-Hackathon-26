# Server
PORT=3000

# Anthropic (required for planning/decomposition)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Nimble agent web search (required for planning + debate web search)
# Endpoint + auth span two Nimble product generations; configure for your account.
NIMBLE_BASE_URL=https://api.webit.live/api/v1/realtime/serp
# Either provide a full Authorization header value...
NIMBLE_AUTH_HEADER=
# ...or Basic-auth credentials (username:password) which the client base64-encodes.
NIMBLE_USERNAME=
NIMBLE_PASSWORD=
# ...or a Bearer token.
NIMBLE_API_KEY=
NIMBLE_SEARCH_ENGINE=google_search

# Datadog LLM Observability via Lapdog (local agent on :8126).
# Run `lapdog npm start`; it sets DD_TRACE_AGENT_URL. Agentless OFF so dd-trace
# sends spans to the local agent. No DD_API_KEY needed for local observation.
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=peercode
DD_LLMOBS_AGENTLESS_ENABLED=0
DD_SITE=datadoghq.com

# ClickHouse Cloud (append-only streams: deltas, debate messages, events, audit)
# Use the HTTPS endpoint (port 8443) from your Cloud service / JDBC string.
CLICKHOUSE_URL=https://<id>.<region>.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=peercode

# GitHub: NOT configured on the server. Each developer's Claude session uses
# their own local git/GitHub auth; the server only coordinates pushes.
